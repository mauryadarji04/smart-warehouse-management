# ── Backend ───────────────────────────────────────────────────
# Database (Postgres)
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_warehouse"
DB_POOL_SIZE=10

# JWT — generate with: openssl rand -base64 32
JWT_SECRET="<min-32-char-random-secret>"
JWT_REFRESH_SECRET="<min-32-char-random-secret-different-from-above>"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (for OTP password reset)
EMAIL_USER="your@email.com"
EMAIL_PASS="your-app-password"

# Cron schedules (BullMQ — cron syntax)
CRON_REORDER_CHECK="0 6 * * *"
CRON_FORECAST_RUN="0 0 * * *"
CRON_EXPIRY_CHECK="0 7 * * *"

# Logging
LOG_LEVEL=info

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
