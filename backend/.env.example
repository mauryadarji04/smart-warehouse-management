# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smart_warehouse?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# Cron Settings
CRON_REORDER_CHECK="0 6 * * *"      # Every day at 6 AM
CRON_EXPIRY_CHECK="0 7 * * *"       # Every day at 7 AM
CRON_FORECAST_RUN="0 0 * * *"       # Every day at midnight

# Alert thresholds
LOW_STOCK_ALERT_DAYS=7
EXPIRY_ALERT_DAYS=30
