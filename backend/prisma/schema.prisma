// ============================================================
// SMART WAREHOUSE — Prisma Schema (All Phases)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH (Phase 7) ──────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// ─── SUPPLIERS (Phase 2) ─────────────────────────────────────
model Supplier {
  id            String          @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  leadTimeDays  Int             @default(7) // avg delivery time
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  products      Product[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// ─── PRODUCTS (Phase 1) ──────────────────────────────────────
model Product {
  id            String          @id @default(cuid())
  sku           String          @unique
  name          String
  description   String?
  category      String?
  unit          String          @default("unit") // pcs, kg, litre, etc.
  costPrice     Float           @default(0)
  sellingPrice  Float           @default(0)
  reorderPoint  Int             @default(10)     // trigger auto-reorder below this
  reorderQty    Int             @default(50)     // how many to order
  orderingCost  Float           @default(50)     // cost per PO (for EOQ)
  holdingCost   Float           @default(2)      // cost to hold 1 unit/year (for EOQ)
  avgDailyDemand Float         @default(0)       // used for forecasting
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  inventory     Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  salesHistory  SalesHistory[]
  forecasts     DemandForecast[]
  alerts        Alert[]

  @@map("products")
}

// ─── INVENTORY / BATCHES (Phase 1 + 5) ───────────────────────
model Inventory {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  batchNo     String?
  quantity    Int       @default(0)
  expiryDate  DateTime?
  location    String?   // warehouse bin/shelf
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transactions InventoryTransaction[]

  @@map("inventory")
}

// ─── INVENTORY TRANSACTIONS (Phase 1) ────────────────────────
model InventoryTransaction {
  id          String          @id @default(cuid())
  inventoryId String
  inventory   Inventory       @relation(fields: [inventoryId], references: [id])
  type        TransactionType
  quantity    Int             // positive = in, negative = out
  reason      String?
  reference   String?         // PO number, sale ID, etc.
  createdAt   DateTime        @default(now())

  @@map("inventory_transactions")
}

enum TransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  EXPIRED_REMOVAL
}

// ─── PURCHASE ORDERS (Phase 2) ───────────────────────────────
model PurchaseOrder {
  id               String      @id @default(cuid())
  poNumber         String      @unique @default(cuid())
  supplierId       String
  supplier         Supplier    @relation(fields: [supplierId], references: [id])
  status           POStatus    @default(DRAFT)
  totalAmount      Float       @default(0)
  isAutoGenerated  Boolean     @default(false) // true = created by EOQ engine
  expectedDelivery DateTime?
  receivedAt       DateTime?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items            PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitCost        Float
  totalCost       Float

  @@map("purchase_order_items")
}

enum POStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

// ─── SALES HISTORY for Forecasting (Phase 4) ─────────────────
model SalesHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  date      DateTime @db.Date
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@map("sales_history")
}

// ─── DEMAND FORECASTS (Phase 4) ──────────────────────────────
model DemandForecast {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  forecastDate    DateTime @db.Date
  predictedQty    Float
  actualQty       Int?     // filled in after the day passes
  algorithm       String   @default("MOVING_AVG_7D")
  createdAt       DateTime @default(now())

  @@unique([productId, forecastDate])
  @@map("demand_forecasts")
}

// ─── ALERTS (Phase 1 + 5) ────────────────────────────────────
model Alert {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  type        AlertType
  message     String
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@map("alerts")
}

enum AlertType {
  LOW_STOCK
  EXPIRY_WARNING
  EXPIRY_CRITICAL
  AUTO_PO_CREATED
  OUT_OF_STOCK
}
